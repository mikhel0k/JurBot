# Для Docker/локально без почты: SEND_LOGIN_CODE_EMAIL=false — код в логах (строка DEV: confirmation code)
LOGIN_FOR_GMAIL=
PASSWORD_FOR_GMAIL=
SEND_LOGIN_CODE_EMAIL=false
API_TOKEN=token
